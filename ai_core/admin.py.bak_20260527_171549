class SkatlazAdminMixin:
    class Media:
        css = {"all": ("ai_core/admin/skatlaz_admin.css",)}


def safe_register(model, admin_class):
    try:
        admin.site.register(model, admin_class)
    except admin.sites.AlreadyRegistered:
        pass


