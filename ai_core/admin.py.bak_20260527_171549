class AIMCPServerAdmin(SkatlazAdminMixin, admin.ModelAdmin):
    list_display = ("name", "task_type", "provider", "model_name", "active", "auto_update", "updated_at")
    list_filter = ("task_type", "provider", "active")
    search_fields = ("name", "system_prompt", "endpoint")
    actions = ["generate_default_config"]
    def generate_default_config(self, request, queryset):
        for obj in queryset:
            obj.config_json = build_mcp_json(obj.task_type, obj.system_prompt or obj.name, "", "all")
            obj.save()
        self.message_user(request, "Config JSON MCP atualizado com Gemini/fallback.")
    generate_default_config.short_description = "Gerar/atualizar config JSON MCP"


class AIAgentAdmin(SkatlazAdminMixin, admin.ModelAdmin):
    list_display = ("name", "task_type", "language", "target_os", "active", "updated_at", "preview")
    list_filter = ("task_type", "language", "target_os", "active")
    search_fields = ("name", "slug", "base_prompt")
    prepopulated_fields = {"slug": ("name",)}
    actions = ["generate_agent_mcp", "scan_templates"]
    def preview(self, obj):
        return format_html('<span style="color:#6B7A2D;font-weight:700">MCP</span>') if obj.mcp_json else "-"
    def generate_agent_mcp(self, request, queryset):
        for obj in queryset:
            data = build_mcp_json(obj.task_type, obj.base_prompt, obj.language, obj.target_os)
            obj.mcp_json = data.get("mcp", data)
            obj.errors_json = data.get("errors_json", obj.errors_json)
            obj.templates_json = data.get("templates_json", obj.templates_json)
            obj.save()
        self.message_user(request, "Agentes atualizados com MCP JSON.")
    generate_agent_mcp.short_description = "Gerar MCP JSON para agentes selecionados"
    def scan_templates(self, request, queryset):
        for obj in queryset:
            obj.templates_json = scan_pugex_templates(obj.language or "html")
            obj.save()
        self.message_user(request, "Templates /pugex/{linguagem}/templates atualizados.")
    scan_templates.short_description = "Varrer templates Pugex por linguagem"


